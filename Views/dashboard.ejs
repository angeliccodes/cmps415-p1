<!DOCTYPE html>
<html lang="en">
<head>
    <title>The Directory - Dashboard</title>
    <%- include('partials/header') %>
</head>
<body>
    <main class="container">
        
        <h1 style="font-size: 3rem;">Angie's Gist Channel.</h1>
        <p style="text-align: center; font-family: 'Playfair Display', serif; font-style: italic; color: #8e0045; margin-top: -20px; margin-bottom: 40px; font-size: 1.2rem;">
            Welcome to the tea party, <%= username %>!
        </p>
        
        <div style="text-align: center; margin-bottom: 40px;">
            <a href="/topics" role="button" class="btn-cute outline">Browse more</a>
        </div>

        <h2 style="text-align: left; font-size: 1.8rem; border-bottom: 1px solid #f4e8ec; padding-bottom: 10px;">Your Active Convos</h2>
        
        <% if (dashboardData.length === 0) { %>
            <p style="color: #888; font-style: italic;">You don't wanna miss out on the fun. Browse the pages or create one to start.</p>
        <% } else { %>
            <% dashboardData.forEach(function(item) { %>
                <article>
                    <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; border-bottom: 1px solid #f4e8ec; padding-bottom: 15px; gap: 15px;">
                        
                        <h3 style="margin: 0; font-size: 1.6rem; text-align: left; flex-grow: 1; line-height: 1.2;"><%= item.topic.title %></h3>
                        
                        <div style="display: flex; gap: 10px; align-items: center; flex-shrink: 0;">
                            
                            <a href="/topics/<%= item.topic._id %>" role="button" class="btn-cute" style="padding: 6px 15px; background-color: #c2185b !important; color: #ffffff !important; border: none; white-space: nowrap;">Hot Gossip</a>
                            
                            <form action="/topics/<%= item.topic._id %>/unsubscribe" method="POST" style="margin: 0;">
                                <button type="submit" class="btn-unsubscribe" style="white-space: nowrap;">Unsubscribe</button>
                            </form>

                        </div>
                    </header>

                    <p style="color: #8e0045; font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">Latest ICYMI:</p>
                    
                    <ul style="list-style-type: none; padding-left: 0;">
                        <% if (item.messages.length === 0) { %>
                            <li><em style="color: #aaa;">No one is talking yet...</em></li>
                        <% } else { %>
                            <% item.messages.forEach(function(msg) { %>
                                <li style="margin-bottom: 8px; font-size: 0.95rem; background: #faf5f7; padding: 10px; border-radius: 6px; border-left: 3px solid #c2185b;">
                                    <strong style="color: #2c1b22;"><%= msg.author.username %>:</strong> 
                                    <span style="color: #444;"><%= msg.content %></span>
                                </li>
                            <% }) %>
                        <% } %>
                    </ul>
                </article>
            <% }) %>
        <% } %>
        
        <div style="text-align: center; margin-top: 40px;">
            <a href="/logout" style="font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px;">Sign Out</a>
        </div>

    </main>
</body>
</html>