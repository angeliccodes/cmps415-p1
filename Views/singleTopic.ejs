<!DOCTYPE html>
<html lang="en">
<head>
    <title><%= topic.title %> - The Directory</title>
    <%- include('partials/header') %>
</head>
<body>
    <main class="container">
        
        <h1 style="font-size: 2.5rem;"><%= topic.title %></h1>
        
        <div style="text-align: center; margin-bottom: 20px;">
            <a href="/dashboard" role="button" class="btn-cute outline">Return to Dashboard</a>
        </div>

        <article style="height: 400px; overflow-y: auto; border: 1px solid #eae0e3 !important; border-radius: 10px; padding: 25px; background: #ffffff !important; box-shadow: inset 0 2px 10px rgba(0,0,0,0.02);">
            <% if (messages.length === 0) { %>
                <p style="text-align: center; color: #888; font-style: italic;">It's quiet in here, start some drama.</p>
            <% } else { %>
                <% messages.forEach(function(msg) { %>
                    
                    <div style="background: #fcf9fa; border-radius: 8px; padding: 12px 18px; margin-bottom: 12px; border-left: 3px solid #c2185b; display: flex; justify-content: space-between; align-items: flex-start;">
                        
                        <div>
                            <strong style="color: #2c1b22; font-size: 1.05rem; letter-spacing: 0.5px;"><%= msg.author.username %>:</strong> 
                            <span style="color: #444; margin-left: 5px;"><%= msg.content %></span>
                        </div>

                        <% if (locals.currentUserId && msg.author._id == locals.currentUserId) { %>
                            <form action="/messages/<%= msg._id %>/delete" method="POST" style="margin: 0;">
                                <button type="submit" style="background: transparent; border: none; padding: 0; margin-left: 15px; color: #a80045; cursor: pointer; box-shadow: none; font-size: 0.75rem; text-transform: uppercase; font-weight: 700; letter-spacing: 1px;" title="Delete Message">Delete</button>
                            </form>
                        <% } %>

                    </div>
                <% }) %>
            <% } %>
        </article>

        <form action="/topics/<%= topic._id %>/messages" method="POST" style="margin-top: 20px;">
            <textarea name="content" rows="3" placeholder="Spill the tea..." required style="border-radius: 8px; border: 1px solid #eae0e3;"></textarea>
            <button type="submit" style="width: 100%; margin-top: 10px;">Send Message</button>
        </form>
        
    </main>
</body>
</html>